# QuizPatenteB environment variables.
# In production this file lives at /etc/quizpatenteb.env (chmod 640, root:azureuser).
# Loaded by deployment/systemd/quizpatenteb.service via EnvironmentFile=.
# Locally, copy to .env at the repo root for development.

# AI: local MLX model (Apple Silicon only). Ignored on the Linux production VM.
AI_MODEL=mlx-community/Qwen3.5-27B-4bit
BACKFILL_DEFINITIONS=false
BACKFILL_CHECKING=false

# Anthropic API key for Claude Haiku definitions. Required on the production VM
# unless CLAUDE_FALLBACK_ENABLED=false. Per-key monthly cap MUST also be set in
# the Anthropic console.
ANTHROPIC_API_KEY=

# Master kill-switch for the Claude definition fallback. When false, the app
# never calls the Anthropic API regardless of ANTHROPIC_API_KEY — useful for
# emergency cost shutoff or for running without paid AI. Default: true.
CLAUDE_FALLBACK_ENABLED=true

# Soft monthly USD cap. App stops calling Anthropic when this is exceeded.
# Set this LOWER than the Anthropic console hard cap.
ANTHROPIC_MONTHLY_USD_CAP=10

# Authentication: 32+ random bytes hex-encoded. Generate with:
#   python -c 'import secrets; print(secrets.token_hex(32))'
SESSION_SECRET=
# Pepper added to user-token hashes. Generate the same way. Rotating invalidates all tokens.
AUTH_TOKEN_PEPPER=
# Email of the operator allowed to call admin endpoints (e.g. GET /api/users).
# Leave empty to disable admin endpoints entirely.
ADMIN_EMAIL=

# CORS allow-list, comma-separated. Empty = same-origin only (production default).
# Dev example: CORS_ORIGINS=http://localhost:5183,http://127.0.0.1:5183
CORS_ORIGINS=

# Email (Gmail SMTP). Used to send the bearer token at registration and for
# the forgot-token flow. If GMAIL_APP_PASSWORD is empty, email is silently
# skipped — registration still returns the token in the API response so the
# SPA can show it.
# Generate the app password at https://myaccount.google.com/apppasswords
# (requires 2FA on the Google account first).
GMAIL_FROM_ADDRESS=eventhorizonpatenteb@gmail.com
GMAIL_APP_PASSWORD=YOUR_PASSWORD_HERE
