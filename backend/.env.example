# Local MLX model used to generate English definitions for Italian driving vocabulary.
# The model runs on-device via mlx-lm (Apple Silicon). Any MLX-compatible model works.
# Definitions are generated in the context of driving/traffic law and cached to disk.
# A background worker pre-caches definitions at startup; user requests get priority.
AI_MODEL='mlx-community/Qwen3.5-27B-4bit'

# Set to false to disable the background definition backfill worker.
# The AI model will still be used on-demand when a user requests a word translation.
BACKFILL_DEFINITIONS=true
