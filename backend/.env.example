# This file contains environment variables for the backend. Copy it to .env and customize as needed.
# AI has already generated definitions for all the included vocabulary, so you can set BACKFILL_DEFINITIONS 
# to false if you don't want to generate any new definitions.
# If you want to generate new definitions (e.g. for new words you add), set BACKFILL_DEFINITIONS to true. 
# The AI model will be used on-demand when a user requests a word translation, and a background worker 
# will pre-cache definitions at startup.


# Local MLX model used to generate English definitions for Italian driving vocabulary.
# The model runs on-device via mlx-lm (Apple Silicon). Any MLX-compatible model works.
# Definitions are generated in the context of driving/traffic law and cached to disk.
# A background worker pre-caches definitions at startup; user requests get priority.
AI_MODEL='mlx-community/Qwen3.5-27B-4bit'

# Set to true to enable the background definition backfill worker.
# The AI model will still be used on-demand when a user requests a word translation.
BACKFILL_DEFINITIONS=false

# Anthropic API key for Claude-based definitions (used when MLX is unavailable,
# e.g. on non-Apple-Silicon servers). Uses claude-haiku-4-5 for fast, cheap definitions.
# Leave empty to skip Claude and fall back to Google Translate.
ANTHROPIC_API_KEY=
